# Copia este archivo como .env y completa los valores
# cp .env.example .env  (Linux/Mac)
# copy .env.example .env  (Windows)

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# ── Base de datos PostgreSQL ─────────────────────────────────────────────────
# Para desarrollo local (sin Docker):
DATABASE_URL=postgresql+asyncpg://studyai:studyai_pass@localhost:5432/studyai_db
# Para Docker Compose, el backend usa la URL con el hostname "db" (se inyecta
# automáticamente en docker-compose.yml y no necesitas cambiar esta línea).

# ── Seguridad JWT ────────────────────────────────────────────────────────────
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=cambia-esto-genera-con-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
